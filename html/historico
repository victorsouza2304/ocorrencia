<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Histórico de Ocorrências</title>
  <link rel="stylesheet" href="historico.css">
</head>
<body>

<div class="card">
  <div class="header">
    <img src="data:image/jpeg;base64," alt="Logo Colégio Cívico-Militar" alt="Logo Colégio Cívico-Militar" class="logo">
    <h1>Histórico de Ocorrências</h1>
  </div>

  <div class="body">

    <div class="dropdown-row">
      <button class="dropdown-btn" onclick="toggleTurma()">
        Turma →
      </button>
      <ul id="listaTurma" class="dropdown-list"></ul>
    </div>

    <div id="resultado" class="resultado"></div>

  </div>
</div>

<script>
const turmas = [
  "9º Ano A", "9º Ano B", "9º Ano C", "9º Ano D",
  "1º Ano A", "1º Ano B", "1º Ano C", "1º Ano D",
  "2º Ano A", "2º Ano B", "2º Ano C", "2º Ano D",
  "3º Ano A", "3º Ano B", "3º Ano C", "3º Ano D"
];

function toggleTurma() {
  const lista = document.getElementById("listaTurma");
  lista.innerHTML = "";

  turmas.forEach(t => {
    const li = document.createElement("li");
    li.textContent = t;
    li.onclick = () => selecionarTurma(t);
    lista.appendChild(li);
  });

  lista.style.display = "block";
}

function selecionarTurma(t) {
  document.getElementById("listaTurma").style.display = "none";
  document.querySelector(".dropdown-btn").textContent = t + " →";
  mostrarHistorico(t);
}

function mostrarHistorico(turma) {
  const resultado = document.getElementById("resultado");
  resultado.innerHTML = "";

  let encontrou = false;

  for (let i = 0; i < localStorage.length; i++) {
    const chave = localStorage.key(i);

    if (chave.startsWith(turma + "_")) {
      const texto = localStorage.getItem(chave);
      if (!texto || texto.trim() === "") continue;

      const aluno = chave.replace(turma + "_", "");

      const card = document.createElement("div");
      card.className = "ocorrencia-card";

      card.innerHTML = `
        <div class="oc-turma">📚 ${turma}</div>
        <div class="oc-aluno">👤 ${aluno}</div>
        <div class="oc-texto">${texto}</div>
      `;

      resultado.appendChild(card);
      encontrou = true;
    }
  }

  if (!encontrou) {
    resultado.innerHTML = "<p class='vazio'>Nenhuma ocorrência encontrada para esta turma.</p>";
  }
}

document.addEventListener("click", function(e) {
  if (!e.target.closest('.dropdown-row')) {
    document.querySelectorAll('.dropdown-list').forEach(lista => {
      lista.style.display = "none";
    });
  }
});
</script>

</body>
